---
import Icon from './Icon.astro';
import {
  LOCALES,
  LOCALE_LABELS,
  LOCALE_FLAGS,
  type Locale,
} from '../i18n/ui';

interface Props {
  current: Locale;
  /** Full href for each locale (where this language's version of the page is). */
  paths: Record<Locale, string>;
}
const { current, paths } = Astro.props;
---

<details class="lang-switch relative">
  <summary
    class="flex h-10 cursor-pointer list-none items-center gap-1.5 rounded-full border border-line px-3 text-sm font-medium text-fg-soft transition hover:border-brand hover:text-fg"
    aria-label="Change language"
  >
    <Icon name="compass" size={16} />
    <span>{LOCALE_FLAGS[current]}</span>
    <span class="chev"><Icon name="arrow-right" size={13} /></span>
  </summary>
  <ul
    class="absolute right-0 z-50 mt-2 w-44 overflow-hidden rounded-xl border border-line bg-surface py-1 shadow-2xl"
  >
    {
      LOCALES.map((loc) => (
        <li>
          <a
            href={paths[loc]}
            class:list={[
              'flex items-center justify-between px-4 py-2.5 text-sm transition hover:bg-surface-2',
              loc === current ? 'text-brand' : 'text-fg-soft',
            ]}
          >
            <span>{LOCALE_LABELS[loc]}</span>
            <span class="text-xs font-semibold text-muted">{LOCALE_FLAGS[loc]}</span>
          </a>
        </li>
      ))
    }
  </ul>
</details>

<style>
  .lang-switch summary::-webkit-details-marker {
    display: none;
  }
  .lang-switch .chev {
    transform: rotate(90deg);
    transition: transform 0.2s;
    opacity: 0.6;
  }
  .lang-switch[open] .chev {
    transform: rotate(-90deg);
  }
</style>

<script>
  // Close the language dropdown when clicking outside.
  document.addEventListener('click', (e) => {
    document.querySelectorAll('details.lang-switch[open]').forEach((d) => {
      if (!d.contains(e.target as Node)) d.removeAttribute('open');
    });
  });
</script>
