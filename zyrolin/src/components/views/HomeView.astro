---
import CategoryGrid from '../CategoryGrid.astro';
import ArticleCard from '../ArticleCard.astro';
import AdSlot from '../AdSlot.astro';
import Icon from '../Icon.astro';
import NewsletterForm from '../NewsletterForm.tsx';
import { getPublishedArticles } from '../../utils/articles';
import { useTranslations, localizedPath, type Locale } from '../../i18n/ui';

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const articles = await getPublishedArticles(lang);

const featured = articles.filter((a) => a.data.featured).slice(0, 4);
const trending = (featured.length ? featured : articles).slice(0, 4);
const latest = articles.slice(0, 6);
---

<!-- Hero -->
<section id="search" class="relative overflow-hidden">
  <div class="mx-auto max-w-3xl px-4 py-20 text-center sm:py-28">
    <span
      class="inline-flex items-center gap-2 rounded-full border border-line bg-surface/60 px-4 py-1.5 text-xs font-medium text-fg-soft backdrop-blur"
    >
      <Icon name="sparkles" size={14} class="text-gold" />
      {t('hero.badge')}
    </span>
    <h1 class="mt-6 font-display text-5xl font-extrabold leading-[1.05] tracking-tight text-fg sm:text-6xl">
      {t('hero.title.a')} <span class="text-gradient">{t('hero.title.b')}</span>
    </h1>
    <p class="mx-auto mt-5 max-w-xl text-lg leading-relaxed text-muted">
      {t('hero.subtitle')}
    </p>

    <!-- Search trigger → opens the command palette -->
    <div class="mx-auto mt-9 max-w-xl">
      <button
        type="button"
        data-open-search
        class="group flex w-full items-center gap-3 rounded-full border border-line bg-surface/80 py-4 pl-5 pr-3 text-left shadow-lg shadow-black/5 backdrop-blur transition hover:border-brand"
      >
        <Icon name="search" size={20} class="text-muted" />
        <span class="flex-1 text-base text-muted">{t('hero.searchPlaceholder')}</span>
        <kbd
          class="hidden rounded-md border border-line px-2 py-1 text-xs font-medium text-muted sm:inline"
          >⌘K</kbd
        >
      </button>
    </div>

    <div class="mt-5 flex flex-wrap justify-center gap-x-3 gap-y-1 text-sm text-muted">
      <span>{t('hero.popular')}</span>
      <a href={localizedPath(lang, 'ai')} class="text-fg-soft transition hover:text-brand">ChatGPT</a>
      <span class="text-line">·</span>
      <a href={localizedPath(lang, 'tech')} class="text-fg-soft transition hover:text-brand">PC</a>
      <span class="text-line">·</span>
      <a href={localizedPath(lang, 'money')} class="text-fg-soft transition hover:text-brand">Budget</a>
      <span class="text-line">·</span>
      <a href={localizedPath(lang, 'gaming')} class="text-fg-soft transition hover:text-brand">FPS</a>
    </div>
  </div>
</section>

<div class="mx-auto max-w-6xl px-4">
  <div class="hairline"></div>

  <!-- Categories -->
  <section class="py-14">
    <div class="mb-7 flex items-end justify-between">
      <div>
        <h2 class="font-display text-3xl font-bold tracking-tight text-fg">
          {t('section.explore')}
        </h2>
        <p class="mt-1.5 text-muted">{t('section.exploreSub')}</p>
      </div>
      <a
        href={localizedPath(lang, 'categories')}
        class="hidden shrink-0 items-center gap-1.5 text-sm font-medium text-brand transition hover:gap-2.5 sm:flex"
      >
        {t('section.viewAll')} <Icon name="arrow-right" size={15} />
      </a>
    </div>
    <CategoryGrid limit={8} lang={lang} />
    <div class="mt-6 text-center sm:hidden">
      <a href={localizedPath(lang, 'categories')} class="text-sm font-medium text-brand">
        {t('section.viewAll')} →
      </a>
    </div>
  </section>

  <AdSlot variant="leaderboard" class="my-4" />

  <!-- Trending -->
  {
    trending.length > 0 && (
      <section class="py-14">
        <h2 class="mb-7 flex items-center gap-2.5 font-display text-3xl font-bold tracking-tight text-fg">
          <Icon name="flame" size={26} class="text-gold" />
          {t('section.trending')}
        </h2>
        <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
          {trending.map((article) => (
            <ArticleCard article={article} lang={lang} />
          ))}
        </div>
      </section>
    )
  }

  <!-- Latest -->
  {
    latest.length > 0 && (
      <section class="py-14">
        <h2 class="mb-7 flex items-center gap-2.5 font-display text-3xl font-bold tracking-tight text-fg">
          <Icon name="compass" size={26} class="text-brand" />
          {t('section.latest')}
        </h2>
        <div class="overflow-hidden rounded-[var(--radius-card)] border border-line bg-surface p-2">
          {latest.map((article, i) => (
            <>
              {i > 0 && <div class="mx-3 h-px bg-line" />}
              <ArticleCard article={article} compact lang={lang} />
            </>
          ))}
        </div>
      </section>
    )
  }

  {
    articles.length === 0 && (
      <section class="py-16 text-center">
        <p class="text-lg text-muted">No articles yet in this language.</p>
      </section>
    )
  }
</div>

<!-- Newsletter -->
<section class="mt-14">
  <div class="mx-auto max-w-5xl px-4">
    <div class="relative overflow-hidden rounded-3xl bg-gradient-to-br from-brand to-brand-2 px-6 py-16 text-center">
      <div class="pointer-events-none absolute -right-16 -top-16 h-64 w-64 rounded-full bg-white/15 blur-3xl"></div>
      <h2 class="font-display text-3xl font-bold text-white sm:text-4xl">
        {t('newsletter.title')}
      </h2>
      <p class="mx-auto mt-3 max-w-md text-white/80">{t('newsletter.subtitle')}</p>
      <div class="mt-8">
        <NewsletterForm client:visible />
      </div>
    </div>
  </div>
</section>
