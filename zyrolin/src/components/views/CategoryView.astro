---
import ArticleCard from '../ArticleCard.astro';
import Breadcrumbs from '../Breadcrumbs.astro';
import AdSlot from '../AdSlot.astro';
import Icon from '../Icon.astro';
import { categoryIcon } from '../../data/categories';
import { localizedCategory } from '../../i18n/categories';
import { getArticlesByCategory } from '../../utils/articles';
import { useTranslations, localizedPath, type Locale } from '../../i18n/ui';

interface Props {
  lang: Locale;
  categorySlug: string;
}
const { lang, categorySlug } = Astro.props;
const t = useTranslations(lang);

const category = localizedCategory(categorySlug, lang)!;
const icon = categoryIcon(categorySlug);
const articles = await getArticlesByCategory(categorySlug, lang);
---

<section class="relative overflow-hidden border-b border-line">
  <div
    class="pointer-events-none absolute -left-24 -top-24 h-72 w-72 rounded-full blur-3xl"
    style={`background:${category.accent}; opacity:.18`}
  >
  </div>
  <div class="mx-auto max-w-6xl px-4 py-12">
    <Breadcrumbs
      crumbs={[
        { label: t('nav.home'), href: localizedPath(lang, '') },
        { label: category.name, href: localizedPath(lang, categorySlug) },
      ]}
    />
    <div class="mt-6 flex items-start gap-5">
      <span
        class="flex h-16 w-16 shrink-0 items-center justify-center rounded-2xl"
        style={`background:color-mix(in oklab, ${category.accent} 18%, transparent); color:${category.accent}`}
      >
        <Icon name={icon} size={30} />
      </span>
      <div>
        <h1 class="font-display text-4xl font-bold tracking-tight text-fg">
          {category.name}
        </h1>
        <p class="mt-2 max-w-2xl leading-relaxed text-muted">
          {category.description}
        </p>
        <p class="mt-3 text-sm font-medium text-fg-soft">
          {articles.length}
          {articles.length === 1 ? t('category.guide') : t('category.guides')}
        </p>
      </div>
    </div>
  </div>
</section>

<div class="mx-auto max-w-6xl px-4 py-12">
  {
    articles.length === 0 ? (
      <div class="rounded-[var(--radius-card)] border border-dashed border-line bg-surface/40 py-20 text-center">
        <span
          class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl"
          style={`background:color-mix(in oklab, ${category.accent} 16%, transparent); color:${category.accent}`}
        >
          <Icon name={icon} size={26} />
        </span>
        <p class="mt-4 font-display text-xl font-bold text-fg">{t('category.comingSoon')}</p>
        <p class="mt-1 text-muted">{t('category.comingSoonText')} {category.name}.</p>
        <a
          href={localizedPath(lang, '')}
          class="mt-5 inline-flex items-center gap-1.5 text-sm font-medium text-brand"
        >
          <Icon name="arrow-right" size={15} class="rotate-180" /> {t('back.home')}
        </a>
      </div>
    ) : (
      <div class="grid gap-8 lg:grid-cols-[1fr_300px]">
        <div class="grid gap-6 sm:grid-cols-2">
          {articles.map((article) => (
            <ArticleCard article={article} lang={lang} />
          ))}
        </div>
        <aside class="space-y-6">
          <AdSlot variant="sidebar" />
        </aside>
      </div>
    )
  }
</div>
