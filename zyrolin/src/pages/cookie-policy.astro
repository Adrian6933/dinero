---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { SITE } from '../data/site';
import { LOCALES, localizedPath } from '../i18n/ui';
const updated = 'June 2026';
const localePaths = Object.fromEntries(
  LOCALES.map((l) => [l, localizedPath(l, '')]),
);
---

<BaseLayout title="Cookie Policy" noindex={true} localePaths={localePaths}>
  <div class="mx-auto max-w-3xl px-4 py-10">
    <Breadcrumbs
      crumbs={[
        { label: 'Home', href: '/' },
        { label: 'Cookie Policy', href: '/cookie-policy' },
      ]}
    />
    <h1 class="mt-5 font-display text-4xl font-semibold tracking-tight text-fg">
      Cookie Policy
    </h1>
    <p class="mt-1 text-sm text-muted">Last updated: {updated}</p>
    <div class="prose-zyrolin mt-6 max-w-none">
      <blockquote>
        <strong>Note:</strong> Starter template. Pair this with a consent banner
        (e.g. a GDPR/CCPA cookie consent tool) before launch.
      </blockquote>
      <p>
        This Cookie Policy explains how {SITE.name} uses cookies and similar
        technologies.
      </p>
      <h2>What are cookies?</h2>
      <p>
        Cookies are small text files stored on your device that help websites
        remember your preferences and understand how you use the site.
      </p>
      <h2>Types of cookies we use</h2>
      <ul>
        <li><strong>Essential cookies</strong> — required for the site to function.</li>
        <li><strong>Analytics cookies</strong> — help us understand site usage.</li>
        <li><strong>Advertising cookies</strong> — used by ad partners to show relevant ads.</li>
      </ul>
      <h2>Managing cookies</h2>
      <p>
        You can control and delete cookies through your browser settings.
        Disabling some cookies may affect how the site works.
      </p>
      <h2>Contact</h2>
      <p>
        Questions about cookies? Email <a href={`mailto:${SITE.email}`}>{SITE.email}</a>.
      </p>
    </div>
  </div>
</BaseLayout>
