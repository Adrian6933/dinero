---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { SITE } from '../data/site';
import { LOCALES, localizedPath } from '../i18n/ui';
const updated = 'June 2026';
const localePaths = Object.fromEntries(
  LOCALES.map((l) => [l, localizedPath(l, '')]),
);
---

<BaseLayout title="Terms & Conditions" noindex={true} localePaths={localePaths}>
  <div class="mx-auto max-w-3xl px-4 py-10">
    <Breadcrumbs
      crumbs={[
        { label: 'Home', href: '/' },
        { label: 'Terms', href: '/terms' },
      ]}
    />
    <h1 class="mt-5 font-display text-4xl font-semibold tracking-tight text-fg">
      Terms & Conditions
    </h1>
    <p class="mt-1 text-sm text-muted">Last updated: {updated}</p>
    <div class="prose-zyrolin mt-6 max-w-none">
      <blockquote>
        <strong>Note:</strong> Starter template — review with a legal
        professional before launch.
      </blockquote>
      <h2>Acceptance of terms</h2>
      <p>
        By using {SITE.name}, you agree to these terms. If you do not agree,
        please do not use the site.
      </p>
      <h2>Use of content</h2>
      <p>
        Our content is provided for general informational purposes. You may not
        republish our content without permission.
      </p>
      <h2>Disclaimer</h2>
      <p>
        Content is provided "as is" without warranties of any kind. We are not
        liable for any outcome resulting from following our guides. Finance and
        health content is informational, not professional advice.
      </p>
      <h2>External links</h2>
      <p>
        We may link to third-party sites and include affiliate links. We are not
        responsible for the content or practices of those sites.
      </p>
      <h2>Changes</h2>
      <p>
        We may update these terms at any time. Continued use of the site means
        you accept the updated terms.
      </p>
    </div>
  </div>
</BaseLayout>
