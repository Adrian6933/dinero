---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import HomeView from '../../components/views/HomeView.astro';
import CategoryView from '../../components/views/CategoryView.astro';
import { CATEGORIES } from '../../data/categories';
import { localizedCategory } from '../../i18n/categories';
import { LOCALES, DEFAULT_LOCALE, type Locale } from '../../i18n/ui';

// One-segment routes that are EITHER a localized home (/es, /de, /fr) OR an
// English category list (/ai, /tech…). Merged into one file so the two dynamic
// route shapes don't collide.
export const getStaticPaths = (() => {
  const paths: any[] = [];
  for (const loc of LOCALES) {
    if (loc !== DEFAULT_LOCALE) {
      paths.push({ params: { seg: loc }, props: { kind: 'home', lang: loc } });
    }
  }
  for (const cat of CATEGORIES) {
    paths.push({
      params: { seg: cat.slug },
      props: { kind: 'category', lang: DEFAULT_LOCALE, categorySlug: cat.slug },
    });
  }
  return paths;
}) satisfies GetStaticPaths;

interface Props {
  kind: 'home' | 'category';
  lang: Locale;
  categorySlug?: string;
}
const { kind, lang, categorySlug } = Astro.props as Props;

const cat =
  kind === 'category' ? localizedCategory(categorySlug!, lang) : undefined;
---

{
  kind === 'home' ? (
    <BaseLayout>
      <HomeView lang={lang} />
    </BaseLayout>
  ) : (
    <BaseLayout
      title={`${cat?.name} — Tutorials & Guides`}
      description={cat?.description}
    >
      <CategoryView lang={lang} categorySlug={categorySlug!} />
    </BaseLayout>
  )
}
