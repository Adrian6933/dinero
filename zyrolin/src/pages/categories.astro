---
import BaseLayout from '../layouts/BaseLayout.astro';
import CategoryGrid from '../components/CategoryGrid.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
---

<BaseLayout
  title="All Topics"
  description="Browse every topic on Zyrolin — AI, tech, money, recipes, home, pets, gaming and more."
>
  <div class="mx-auto max-w-6xl px-4 py-10">
    <Breadcrumbs
      crumbs={[
        { label: 'Home', href: '/' },
        { label: 'All Topics', href: '/categories' },
      ]}
    />
    <h1 class="mt-5 font-display text-4xl font-semibold tracking-tight text-fg">
      All topics
    </h1>
    <p class="mt-2 max-w-2xl text-muted">
      Every category on Zyrolin. New guides are added every week — categories
      grow at their own pace, so some have more than others.
    </p>

    <div class="mt-8">
      <CategoryGrid />
    </div>
  </div>
</BaseLayout>
