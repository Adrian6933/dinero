---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
---

<BaseLayout title="Page not found" noindex={true}>
  <div class="mx-auto flex max-w-xl flex-col items-center px-4 py-28 text-center">
    <span
      class="flex h-16 w-16 items-center justify-center rounded-2xl border border-line bg-surface text-brand"
    >
      <Icon name="compass" size={32} />
    </span>
    <h1 class="mt-6 font-display text-5xl font-semibold text-fg">404</h1>
    <p class="mt-3 text-lg text-muted">
      We couldn't find that page. It may have moved or never existed.
    </p>
    <div class="mt-7 flex gap-3">
      <a
        href="/"
        class="rounded-full bg-brand px-6 py-2.5 font-semibold text-white transition hover:bg-brand-2"
      >
        Go home
      </a>
      <a
        href="/categories"
        class="rounded-full border border-line px-6 py-2.5 font-semibold text-fg-soft transition hover:bg-surface-2"
      >
        Browse topics
      </a>
    </div>
  </div>
</BaseLayout>
